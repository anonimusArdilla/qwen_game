# APP_ENV: dev | staging | prod
APP_ENV=dev

# Supabase project URL (required once cloud sync / leaderboard is enabled)
SUPABASE_URL=

# Supabase anon public key (required once cloud sync / leaderboard is enabled)
SUPABASE_ANON_KEY=

# AppLovin MAX SDK key (required once ads are enabled)
APPLOVIN_SDK_KEY=

# AppLovin MAX rewarded ad unit id (required once ads are enabled)
APPLOVIN_REWARDED_AD_UNIT_ID=

# AppLovin MAX interstitial ad unit id (required once ads are enabled)
APPLOVIN_INTERSTITIAL_AD_UNIT_ID=

